VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Optional legacy name accepted by the client when the publishable key is absent.
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Admin panel server-side key — required to access /admin
# Access via /admin?key=YOUR_SECRET or set Authorization: Bearer YOUR_SECRET header
# Also accepted as snickerland-admin-key cookie
ADMIN_KEY=change-me-to-a-random-secret

# YouTube cookies for yt-dlp/ytdl-core — required to bypass bot detection
# Get them from Chrome: F12 → Application → Cookies → youtube.com
# Copy key=value pairs separated by "; " (e.g. "VISITOR_INFO1_LIVE=xxx; YSC=yyy; LOGIN_INFO=zzz")
YT_COOKIES=
